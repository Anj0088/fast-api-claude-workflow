# Common ignores for Python projects

# Virtual environments
venv/
venv-*/
.venv/
env/
ENV/

# Environment variables
.env
.env.*
.env.local

# Python bytecode, caches, and test/mypy caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/

# Packaging / distribution
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# Coverage
.coverage
.coverage.*
coverage.xml
htmlcov/

# IDEs and editors
.vscode/
.idea/
*.iml

# macOS
.DS_Store

# Logs
*.log
logs/

# Misc
node_modules/
*.sqlite3
*.db
*.sqlite

# NOTE: Review and remove any entries you want tracked in the repo.